{
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },

  "agents": {
    "defaults": {
      "elevatedDefault": "full",
      "timeoutSeconds": 1800,
      "subagents": {
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 3,
        "runTimeoutSeconds": 1800
      },
      "memorySearch": {
        "enabled": true,
        "sources": ["memory"],
        "extraPaths": ["knowledge"],
        "sync": {
          "onSearch": true,
          "watch": true,
          "watchDebounceMs": 1500
        }
      }
    },
    "list": [
      {
        "id": "daily-assistant",
        "name": "日常助理",
        "default": true,
        "workspace": "Agents/daily-assistant",
        "tools": {
          "elevated": {
            "enabled": true,
            "allowFrom": { "webchat": ["*"], "web": ["*"] }
          },
          "exec": { "security": "full" }
        }
      },
      {
        "id": "web-operator",
        "name": "网页代办",
        "workspace": "Agents/web-operator",
        "tools": {
          "elevated": {
            "enabled": true,
            "allowFrom": { "webchat": ["*"], "web": ["*"] }
          },
          "exec": { "security": "full" }
        }
      },
      {
        "id": "slide-maker",
        "name": "演示文稿助手",
        "workspace": "Agents/slide-maker",
        "tools": {
          "elevated": {
            "enabled": true,
            "allowFrom": { "webchat": ["*"], "web": ["*"] }
          },
          "exec": { "security": "full" }
        }
      },
      {
        "id": "research-scout",
        "name": "信息侦察员",
        "workspace": "Agents/research-scout",
        "tools": {
          "elevated": {
            "enabled": true,
            "allowFrom": { "webchat": ["*"], "web": ["*"] }
          },
          "exec": { "security": "full" }
        }
      },
      {
        "id": "writing-desk",
        "name": "写作台",
        "workspace": "Agents/writing-desk",
        "tools": {
          "elevated": {
            "enabled": true,
            "allowFrom": { "webchat": ["*"], "web": ["*"] }
          },
          "exec": { "security": "full" }
        }
      }
    ]
  },

  "tools": {
    "profile": "full",
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "webchat": ["*"],
        "web": ["*"],
        "slack": ["*"],
        "telegram": ["*"],
        "discord": ["*"]
      }
    },
    "exec": {
      "security": "full",
      "host": "gateway"
    },
    "agentToAgent": {
      "enabled": true,
      "allow": ["daily-assistant", "web-operator", "slide-maker", "research-scout", "writing-desk"]
    },
    "sessions": {
      "visibility": "all"
    },
    "web": {
      "search": {
        "provider": "searxng"
      }
    }
  },

  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/chromium",
    "noSandbox": true,
    "extraArgs": [
    "--disable-dev-shm-usage",
    "--disable-dbus",
    "--ozone-platform=headless"
    ]
  },

  "plugins": {
    "enabled": true,
    "allow": ["searxng", "memory-core"],
    "slots": {
      "memory": "memory-core"
    },
    "entries": {
      "memory-core": {
        "enabled": true
      },
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "https://ai.infox-med.com:48888"
          }
        }
      }
    }
  },

  "memory": {
    "backend": "builtin",
    "citations": "auto",
    "qmd": {
      "includeDefaultMemory": true,
      "command": "/root/.openclaw/qmd-runner.sh",
      "searchMode": "search",
      "update": {
        "interval": "5m",
        "debounceMs": 15000,
        "onBoot": true,
        "waitForBootSync": false
      },
      "limits": {
        "maxResults": 6,
        "timeoutMs": 30000
      },
      "scope": {
        "default": "deny",
        "rules": [
          { "action": "allow", "match": { "chatType": "direct" } }
        ]
      }
    }
  },

  "session": {
    "dmScope": "per-channel-peer",
    "agentToAgent": {
      "maxPingPongTurns": 3
    },
    "reset": {
      "mode": "idle",
      "idleMinutes": 10080
    }
  }
}
